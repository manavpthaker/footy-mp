{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/football/**",
              "ui_kits/visualizer/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Spline Sans Mono))/i]",
        "message": "Font not provided by the design system. Available: Spline Sans Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|height|fill|track|key|ref|className|style|children)$/]",
        "message": "<BarMeter> doesn't accept that prop. Declared props: value, max, height, fill, track."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompetitionBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|name|tone|size|key|ref|className|style|children)$/]",
        "message": "<CompetitionBadge> doesn't accept that prop. Declared props: code, name, tone, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompetitionBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:pitch|sky|gold|neutral)$/]",
        "message": "<CompetitionBadge> tone must be one of 'pitch' | 'sky' | 'gold' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompetitionBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<CompetitionBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactorBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|z|key|ref|className|style|children)$/]",
        "message": "<FactorBar> doesn't accept that prop. Declared props: label, z."
      },
      {
        "selector": "JSXOpeningElement[name.name='FixtureGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|right|children|key|ref|className|style|children)$/]",
        "message": "<FixtureGroup> doesn't accept that prop. Declared props: label, right, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FollowButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:following|onToggle|label|key|ref|className|style|children)$/]",
        "message": "<FollowButton> doesn't accept that prop. Declared props: following, onToggle, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormPills'] > JSXAttribute > JSXIdentifier[name!=/^(?:results|size|titles|key|ref|className|style|children)$/]",
        "message": "<FormPills> doesn't accept that prop. Declared props: results, size, titles."
      },
      {
        "selector": "JSXOpeningElement[name.name='StandingRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:team|flag|rank|P|W|D|L|GF|GA|Pts|status|key|ref|className|style|children)$/]",
        "message": "<StandingRow> doesn't accept that prop. Declared props: team, flag, rank, P, W, D, L, GF, GA, Pts, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='StandingRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:qualified|eliminated|active)$/]",
        "message": "<StandingRow> status must be one of 'qualified' | 'eliminated' | 'active'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|active|title|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, active, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeagueTableRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:pos|team|flag|P|W|D|L|GD|Pts|zone|form|followed|key|ref|className|style|children)$/]",
        "message": "<LeagueTableRow> doesn't accept that prop. Declared props: pos, team, flag, P, W, D, L, GD, Pts, zone, form, followed."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|homeFlag|home|awayFlag|away|right|onClick|key|ref|className|style|children)$/]",
        "message": "<MatchRow> doesn't accept that prop. Declared props: date, homeFlag, home, awayFlag, away, right, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:lead|name|club|caps|isKey|onClick|key|ref|className|style|children)$/]",
        "message": "<PlayerCard> doesn't accept that prop. Declared props: lead, name, club, caps, isKey, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayerStatFigure'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|accent|key|ref|className|style|children)$/]",
        "message": "<PlayerStatFigure> doesn't accept that prop. Declared props: value, label, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProbabilityBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:home|draw|away|homeLabel|awayLabel|height|key|ref|className|style|children)$/]",
        "message": "<ProbabilityBar> doesn't accept that prop. Declared props: home, draw, away, homeLabel, awayLabel, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|color|label|key|ref|className|style|children)$/]",
        "message": "<RatingRing> doesn't accept that prop. Declared props: value, max, size, color, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScorelineGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:home|away|matrix|max|key|ref|className|style|children)$/]",
        "message": "<ScorelineGrid> doesn't accept that prop. Declared props: home, away, matrix, max."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:tick|trailing|children|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: tick, trailing, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|accent|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, unit, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
